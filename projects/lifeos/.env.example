# LifeOS — environment template.
# The app runs fully with NONE of these set (local demo mode).
# Add keys to activate production integrations.

# --- Auth: Clerk (preferred per the tool library) -------------------------
# When set, swap the local AuthProvider internals for Clerk's <ClerkProvider>.
# See SETUP-KEYS.md for the exact swap.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Database: Neon (preferred Postgres) ----------------------------------
# For persisting people/tasks server-side instead of localStorage.
DATABASE_URL=

# --- Analytics: Plausible (preferred, privacy-first) ----------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- Email: Resend (preferred transactional) ------------------------------
RESEND_API_KEY=
